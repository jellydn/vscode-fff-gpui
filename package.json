{
  "name": "vscode-fff-gpui",
  "displayName": "fff-gpui",
  "version": "0.1.6",
  "description": "Fast fuzzy file finder and grep — integrates the fff-gpui native picker into VS Code",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "icon": "logo.png",
  "publisher": "jellydn",
  "repository": {
    "type": "git",
    "url": "https://github.com/jellydn/vscode-fff-gpui"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onCommand:fff-gpui.findFiles",
    "onCommand:fff-gpui.grepFiles",
    "onCommand:fff-gpui.pickFileFromGitStatus",
    "onCommand:fff-gpui.findTodoFixme",
    "onCommand:fff-gpui.resumeSearch",
    "onCommand:fff-gpui.runCustomTask"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fff-gpui.findFiles",
        "title": "fff-gpui: Find Files"
      },
      {
        "command": "fff-gpui.grepFiles",
        "title": "fff-gpui: Grep Files"
      },
      {
        "command": "fff-gpui.pickFileFromGitStatus",
        "title": "fff-gpui: Pick File from Git Status"
      },
      {
        "command": "fff-gpui.findTodoFixme",
        "title": "fff-gpui: Find TODO/FIXME"
      },
      {
        "command": "fff-gpui.resumeSearch",
        "title": "fff-gpui: Resume Last Search"
      },
      {
        "command": "fff-gpui.runCustomTask",
        "title": "fff-gpui: Run Custom Task"
      }
    ],
    "keybindings": [
      {
        "command": "fff-gpui.findFiles",
        "key": "cmd+k cmd+p",
        "mac": "cmd+k cmd+p"
      },
      {
        "command": "fff-gpui.grepFiles",
        "key": "cmd+k cmd+f",
        "mac": "cmd+k cmd+f"
      },
      {
        "command": "fff-gpui.pickFileFromGitStatus",
        "key": "cmd+k cmd+s",
        "mac": "cmd+k cmd+s"
      },
      {
        "command": "fff-gpui.findTodoFixme",
        "key": "cmd+k cmd+t",
        "mac": "cmd+k cmd+t"
      },
      {
        "command": "fff-gpui.resumeSearch",
        "key": "cmd+k cmd+r",
        "mac": "cmd+k cmd+r"
      }
    ],
    "configuration": {
      "title": "fff-gpui",
      "properties": {
        "fff-gpui.socketPath": {
          "type": "string",
          "default": "",
          "description": "Custom Unix socket path for the fff-gpui daemon (auto-detected from $HOME if empty)"
        },
        "fff-gpui.customTasks": {
          "type": "array",
          "default": [],
          "description": "Custom shell tasks to run via 'fff-gpui: Run Custom Task'",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Display name for the task"
              },
              "command": {
                "type": "string",
                "description": "Shell command to execute"
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bump": "bumpp",
    "package": "vsce package --no-dependencies",
    "release": "bash scripts/release.sh",
    "release:dry": "bash scripts/release.sh --dry-run",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "bumpp": "^9.0.0",
    "ovsx": "^1.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "reactive-vscode": "^0.4.0"
  }
}
