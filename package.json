{
  "name": "vscode-fff-gpui",
  "displayName": "fff-gpui",
  "version": "0.1.1",
  "description": "Fast fuzzy file finder and grep — integrates the fff-gpui native picker into VS Code",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "icon": "logo.png",
  "publisher": "jellydn",
  "repository": {
    "type": "git",
    "url": "https://github.com/jellydn/vscode-fff-gpui"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onCommand:fff-gpui.findFiles",
    "onCommand:fff-gpui.grepFiles"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fff-gpui.findFiles",
        "title": "fff-gpui: Find Files"
      },
      {
        "command": "fff-gpui.grepFiles",
        "title": "fff-gpui: Grep Files"
      }
    ],
    "keybindings": [
      {
        "command": "fff-gpui.findFiles",
        "key": "cmd+k cmd+p",
        "mac": "cmd+k cmd+p"
      },
      {
        "command": "fff-gpui.grepFiles",
        "key": "cmd+k cmd+f",
        "mac": "cmd+k cmd+f"
      }
    ],
    "configuration": {
      "title": "fff-gpui",
      "properties": {
        "fff-gpui.socketPath": {
          "type": "string",
          "default": "",
          "description": "Custom Unix socket path for the fff-gpui daemon (auto-detected from $HOME if empty)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bump": "bumpp",
    "package": "vsce package --no-dependencies",
    "release": "bash scripts/release.sh",
    "release:dry": "bash scripts/release.sh --dry-run",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "bumpp": "^9.0.0",
    "ovsx": "^1.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "reactive-vscode": "^0.3.0"
  }
}
